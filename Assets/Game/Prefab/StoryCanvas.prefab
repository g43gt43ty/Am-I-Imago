  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TypewriterTransition
  displayText: {fileID: 1172124326954726033}
  textEntries:
  - text: "\u041F\u0440\u043E\u0441\u043D\u0438\u0441\u044C \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
      \u0437\u0435\u043C\u043B\u0438"
  - text: "\u0413\u043B\u0438\u043D\u0430 \u0447\u0442\u043E \u043C\u0435\u0447\u0442\u0430\u0435\u0442
      \u043E \u043A\u0440\u044B\u043B\u044C\u044F\u0445, \u043D\u043E \u043F\u043E\u043A\u0430
      \u043D\u0435 \u0437\u043D\u0430\u0435\u0442 \u043E\u0431 \u044D\u0442\u043E\u043C."
  - text: "\u0422\u0432\u043E\u044F \u0441\u0438\u043B\u0430 \u2014 \u043F\u0435\u0440\u0432\u044B\u0439
      \u0448\u0430\u0433 \u043A \u0442\u0432\u043E\u0435\u0439 \u0441\u043B\u0430\u0431\u043E\u0441\u0442\u0438."
  - text: "\u041F\u0440\u043E\u0431\u0443\u0434\u0438\u0441\u044C, \u0413\u043E\u043B\u0435\u043C.
      \u0412\u043F\u0435\u0440\u0435\u0434\u0438 \u0434\u0432\u0435\u0440\u044C \u0438
      \u0442\u043E, \u0447\u0442\u043E \u0437\u0430 \u043D\u0435\u0439..."
  - text: ...
  letterDelay: 0.05
  typeSound: {fileID: 8300000, guid: bb9281cc7a19efb4db99efd3ea512def, type: 3}
  audioSource: {fileID: 0}
  fadeDuration: 1.5
  canvasGroup: {fileID: 8130277264849223329}
  nextSceneName: Test
